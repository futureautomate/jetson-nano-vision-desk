# Copy to .env (which is gitignored) and fill in. On the Jetson, keep it OUTSIDE the
# synced repo dir if you prefer — e.g. ~/jetson-vision-desk-data/.env — and point
# COMPANION_ENV at it. Never commit the real .env.

# --- Gemini "brain" layer (optional — the vision reflexes work without it) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash          # NOT gemini-2.0-flash (no free quota / retired for new projects)
GEMINI_INTERVAL_S=8                    # how often to ask Gemini about the scene

# --- Telegram (optional — snapshot on a Gemini alert, and a ping when a person arrives) ---
TELEGRAM_BOT_TOKEN=                     # from @BotFather
TELEGRAM_CHAT_ID=                       # message the bot, then GET api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_ALERT_COOLDOWN_S=300           # min seconds between alert messages (no spam)
TELEGRAM_PERSON_COOLDOWN_S=300          # min seconds between "person at the desk" pings (defaults to the alert cooldown)

# --- tuning ---
DETECT_CONFIDENCE=0.5                  # detectnet min confidence
NO_PERSON_TIMEOUT_S=20                 # lamp off after this long with no person
CAMERA_WIDTH=640                       # capture res; detectnet downscales to 300x300 anyway, and the
CAMERA_HEIGHT=480                      #   C270's MJPEG is decoded on the Nano's CPU — keep it small (640x480 / 640x360)
