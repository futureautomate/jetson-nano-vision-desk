# Copy to .env (which is gitignored) and fill in. On the Jetson, keep it OUTSIDE the
# synced repo dir if you prefer — e.g. ~/jetson-vision-desk-data/.env — and point
# COMPANION_ENV at it. Never commit the real .env.

# --- Gemini "brain" — the identification layer (required for actual identifications) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash          # NOT gemini-2.0-flash (no free quota / retired for new projects)
GEMINI_BACKOFF_S=30                    # after any Gemini failure, pause new attempts for this long.
                                       #   keeps us under the free-tier 20 RPM rate limit; manual
                                       #   "Identify now" still triggers immediately, bypassing this.

# --- Telegram (optional — each identification logs a snapshot + summary to your bot) ---
TELEGRAM_BOT_TOKEN=                     # from @BotFather
TELEGRAM_CHAT_ID=                       # message the bot, then GET api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_IDENTIFY_COOLDOWN_S=30         # min seconds between log messages (de-dupes flickering re-detections)

# --- engine tuning ---
DETECT_CONFIDENCE=0.4                  # detectnet min confidence (lower = triggers more readily)
STABLE_S=2.0                           # how long an object must be steady in frame before we ask Gemini
CLEAR_S=3.0                            # how long the frame must be clear before we re-arm for the next object
CAMERA_WIDTH=640                       # detectnet downscales to 300x300 anyway, and the C270's raw YUY2
CAMERA_HEIGHT=480                      #   stream is available at 640x480 (no CPU JPEG decode at this res)
