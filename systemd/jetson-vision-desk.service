[Unit]
Description=Jetson Nano Vision Desk — HUD + vision/reflex loop on the DWIN screen
# the HUD needs an X session; on a stock JetPack desktop image that's the
# graphical target's :0. If you boot to console, run the loop with --demo instead.
After=graphical.target nv-l4t-bootloader-config.service
Wants=graphical.target

[Service]
Type=simple
User=jetson
# the desktop session owns DISPLAY :0. XAUTHORITY depends on the display manager:
#   gdm3   -> /run/user/1000/gdm/Xauthority   (JetPack 4.6 default; 1000 = `id -u jetson`)
#   lightdm-> /home/jetson/.Xauthority  (or /var/run/lightdm/...)
# check `echo $XAUTHORITY` inside the desktop session if it won't connect.
Environment=DISPLAY=:0
Environment=XAUTHORITY=/run/user/1000/gdm/Xauthority
Environment=DBUS_SESSION_BUS_ADDRESS=unix:path=/run/user/1000/bus
WorkingDirectory=/home/jetson/jetson-vision-desk
# kiosk: silence GNOME notification banners so they don't pop over the fullscreen HUD
# (leading '-' = don't fail the unit if gsettings/dbus isn't there)
ExecStartPre=-/usr/bin/gsettings set org.gnome.desktop.notifications show-banners false
ExecStart=/usr/bin/python3 -m src.main --hud
Restart=on-failure
RestartSec=5

[Install]
WantedBy=graphical.target
